# ─────────────────────────────────────────────────────────────────────────────
# Trading Dashboard – Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in your values.
# NEVER commit .env.local to version control.

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate a strong secret with: openssl rand -base64 32
NEXTAUTH_SECRET=replace_with_a_random_32_char_secret_string
# Your deployment URL (use http://localhost:3000 for local dev)
NEXTAUTH_URL=http://localhost:3000

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Get a free cluster at https://cloud.mongodb.com
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your_user:your_password@cluster0.xxxxx.mongodb.net/trading_dashboard?retryWrites=true&w=majority
MONGODB_DB=trading_dashboard

# ── Finnhub (Stocks, ETFs, Forex, Commodities) ───────────────────────────────
# Get a FREE key at https://finnhub.io/register
# Free tier: 60 API calls/minute — generous for this dashboard
# Used for: S&P 500 (SPY), NASDAQ (QQQ), Dow (DIA), Bonds (TLT), WTI (USO), Gold (GLD), DXY
FINNHUB_KEY=your_finnhub_api_key_here

# ── CoinGecko (Crypto prices) ─────────────────────────────────────────────────
# No key required for the public API (50 calls/min free).
# All 10 portfolio coins are fetched in a single request.

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Trading Discipline Dashboard
